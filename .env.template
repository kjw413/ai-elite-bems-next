# =============================================
# 이 파일을 복사하여 '.env' 이름으로 저장한 후,
# 아래 각 항목의 실제 값을 채워 넣으세요.
# .env 파일은 절대 git/외부에 공유하지 마세요.
# =============================================

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fems_db
DB_POOL_SIZE=8

# Admin Account (Full Privileges) — 호스트 PC 접속 시 사용
DB_ADMIN_USER=root

# Viewer Account (Read-Only) — 외부 PC 접속 시 사용
DB_VIEWER_USER=fems_viewer
DB_VIEWER_PASSWORD=your_viewer_password

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key

# KMA(기상청) API Hub Configuration
KMA_API_KEY=your_kma_api_key

# Outbound HTTPS/TLS
# 기본은 TLS 검증 ON입니다. 사내 SSL 검사 프록시 인증서는 Windows 인증서 저장소에 등록하고 truststore를 사용하세요.
# 임시 장애 대응으로만 true를 사용하세요.
HTTP_INSECURE_SKIP_VERIFY=false

# External source workbooks
# PC/drive 변경 시 SAMPLED_DB_DIR만 바꾸면 기본 파일명이 함께 이동합니다.
SAMPLED_DB_DIR=E:\Sampled DB
# 필요할 때만 개별 경로를 override하세요.
# ENERGY_SOURCE_XLSX=E:\Sampled DB\RawDB_에너지.xlsx
# WIP_SUMMARY_XLSX=E:\Sampled DB\DB_재공품.xlsx
# WIP_ITEM_MASTER_XLSX=E:\Sampled DB\RawDB_재공품.xlsx
# PRODUCTION_RAW_XLSX=E:\Sampled DB\RawDB_생산실적.xlsx
# PRODUCTION_DW_XLSX=E:\Sampled DB\DB_생산실적.xlsx
# PRODUCTION_RAW_DIR=E:\Sampled DB\Raw_생산실적

# v5 Model Retraining (Optional)
# - Weight update runs on the most recent business-days window
# - Full retrain runs only if the last full training is older than the interval
V5_WEIGHT_UPDATE_WINDOW_BDAYS=60
V5_FULL_RETRAIN_MIN_INTERVAL_HOURS=678
V5_FULL_RETRAIN_N_ESTIMATORS=3000


# =============================================
# Automation Modules (Manual .bat Triggers)
# =============================================

# ----- Gmail SMTP (run_daily_mail.bat) -----
# Gmail 2단계 인증 활성화 → 앱 비밀번호(16자리) 발급 후 SMTP_APP_PASSWORD 에 입력
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_APP_PASSWORD=your_16char_app_password
SMTP_USE_TLS=true
# 사내 SSL 검사 proxy 환경에서만 임시 우회용. 기본은 truststore(=Windows 인증서 저장소) 사용 권장.
# SMTP_INSECURE_SKIP_VERIFY=false
MAIL_SENDER_NAME=your_sender_name

# 수신자(콤마 구분, 다중 가능)
MAIL_RECIPIENTS=recipient@example.com
MAIL_CC=
MAIL_SUBJECT_PREFIX=[생산기술팀][일일 에너지 이상 Alert]

# ----- Daily Report (run_daily_mail.bat) -----
# 기준일 = today - DAILY_REPORT_REFERENCE_OFFSET_DAYS (기본 2 → D-2)
DAILY_REPORT_REFERENCE_OFFSET_DAYS=2
# 메일 생성 전 RawDB_에너지.xlsx 변경분을 DB에 먼저 반영합니다.
DAILY_REPORT_SYNC_BEFORE_BUILD=true
# 비어 있으면 DB에 존재하는 모든 공장
DAILY_REPORT_FACTORIES=
DAILY_REPORT_INCLUDE_TOTAL=true
# 메일 하단 추이 차트 일수
DAILY_REPORT_CHART_DAYS=14
