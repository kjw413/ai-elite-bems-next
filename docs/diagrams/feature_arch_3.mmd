flowchart TD
    PT["(공장 × 대상)<br/>예: 남양주2 · 전력"]
    PT --> M1 & M3 & M4

    subgraph ALG["각 모델 = 3 알고리즘"]
        direction LR
        L["LightGBM"]
        X["XGBoost"]
        CB["CatBoost"]
