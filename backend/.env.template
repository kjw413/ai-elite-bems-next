# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=DB_NAME

# Admin Account (Full Privileges)
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD

# Viewer Account (Read-Only)
DB_VIEWER_USER=fems_viewer
DB_VIEWER_PASSWORD=viewer1234

# OpenAI API Configuration
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# KMA(기상청) API Hub Configuration
KMA_API_KEY=YOUR_KMA_API_KEY

# v5 Model Retraining (Optional)
# - Weight update runs on the most recent business-days window
# - Full retrain runs only if the last full training is older than the interval
V5_WEIGHT_UPDATE_WINDOW_BDAYS=60
V5_FULL_RETRAIN_MIN_INTERVAL_HOURS=678
V5_FULL_RETRAIN_N_ESTIMATORS=3000

# =============================================
# External Excel Data Source (RPA 산출물 폴더)
# =============================================
# 에너지/생산실적/재공품 원천 엑셀이 있는 폴더.
# 폴더/드라이브가 바뀌면 여기 한 줄만 수정하면 됩니다 (paths.py가 모든 파일 경로를 이 폴더 기준으로 해석).
SAMPLED_DB_DIR=E:\DB_MIS

# =============================================
# Automation Modules (Manual .bat Triggers)
# =============================================

# ----- Gmail SMTP (run_daily_mail.bat) -----
# Gmail 2단계 인증 활성화 → 앱 비밀번호(16자리) 발급 후 SMTP_APP_PASSWORD 에 입력
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_SMTP_MAIL_ADDRESS
SMTP_APP_PASSWORD=YOUR_SMTP_APP_PASSWORD
SMTP_USE_TLS=true
MAIL_SENDER_NAME=BEMS_ADMIN

# 수신자(콤마 구분, 다중 가능)
MAIL_RECIPIENTS=
MAIL_CC=
MAIL_SUBJECT_PREFIX=[생산기술팀][일일 에너지 원단위]

# ----- Daily Report (run_daily_mail.bat) -----
# 기준일 = today 에서 평일 근무일(주말·공휴일 제외) 기준 N칸 역산 (기본 1 → 근무일 D-1)
# 예: 오늘 월요일이면 지난주 금요일, 화요일이면 월요일이 기준일. 비교는 기준일의 직전 근무일.
DAILY_REPORT_REFERENCE_OFFSET_DAYS=1
# 비어 있으면 DB에 존재하는 모든 공장
DAILY_REPORT_FACTORIES=
DAILY_REPORT_INCLUDE_TOTAL=true
# 메일 하단 추이 차트 일수
DAILY_REPORT_CHART_DAYS=14

