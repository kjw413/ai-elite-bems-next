# 이 파일을 복사해 .env.local 로 저장한 뒤 필요 시 수정하세요.
# 비워 두면 브라우저 주소의 호스트명:8000/api/v1 을 자동 사용합니다.
# 예) http://BEMS-PC:3000 으로 접속하면 API는 http://BEMS-PC:8000/api/v1 을 호출.
NEXT_PUBLIC_BEMS_API_BASE=

# 이전 배포의 NEXT_PUBLIC_BEMS_API_URL도 호환되지만, 위 BASE 설정이 항상 우선합니다.

# FastAPI 쪽 설정은 프런트가 아니라 실행 환경변수로 지정합니다.
#   BEMS_CORE_ROOT   기존 파이썬 프로젝트 루트 (기본: ../legacy)
#   DB_VIEWER_USER / DB_VIEWER_PASSWORD  FastAPI 직접 조회용 DB 계정 (필수, SELECT 권한만 부여)
#   BEMS_ADMIN_IPS   서버 PC 외 관리자 허용 IP (콤마 구분)
#   BEMS_ALLOWED_ORIGINS  기본 목록에 추가할 프런트 주소 (예: http://bems-alias:3000)
